# ─── Backend Environment Variables ───────────────────────────────
# Copy this file to ".env" and fill in your real values:
#   cp .env.example .env

# MongoDB connection string.
# Local install:   mongodb://127.0.0.1:27017/tank_database
# MongoDB Atlas:   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/tank_database?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/tank_database

# Port the Express API listens on.
PORT=5000

# Comma-separated list of origins allowed to call the API (the Vite dev server).
CLIENT_ORIGIN=http://localhost:5173

# ─── Local-only AI bulk importer ─────────────────────────────────
# Set to "true" ONLY in local dev to enable the AI import routes
# (POST /api/tanks/generate, /bulk). Leave UNSET / "false" in production —
# the feature must never be deployed (no auth, calls an AI model).
ENABLE_AI_IMPORT=false

# Provider: "groq" (free hosted, ~70B — recommended) or "ollama" (fully local).
AI_PROVIDER=groq

# Groq — free, fast, much better quality than a small local model.
# Get a free API key at https://console.groq.com/keys
# Model IDs: https://console.groq.com/docs/models
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama fallback — only used when AI_PROVIDER=ollama.
#   brew install --cask ollama-app && open -a Ollama && ollama pull qwen2.5:7b
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
